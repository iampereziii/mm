sequenceDiagram
    actor User
    participant CLI as index.ts
    participant Config as config.ts
    participant Nodes as api/nodes.ts
    participant Client as api/client.ts
    participant Magnolia as Source Magnolia (.rest)
    participant Schema as schema.ts
    participant FS as File System
    participant MigrateAPI as api/migrate.ts
    participant TargetClient as api/target-client.ts
    participant Target as Target Magnolia (.rest-v2)

    User->>CLI: npm run dev -- schema /page/path

    CLI->>Config: import config
    Config-->>CLI: { baseUrl, username, password, instancePath }

    CLI->>Nodes: getPageSchema("/page/path")
    Nodes->>Client: apiFetch("/nodes/v1/website/page/path", { depth:10, includeMetadata:true })

    Client->>Client: build URL + Basic Auth header
    Client->>Magnolia: GET /local/.rest/nodes/v1/website/page/path?depth=10&includeMetadata=true
    note over Client,Magnolia: console.error("--> url") logged to stderr

    alt HTTP 200
        Magnolia-->>Client: MagnoliaNode JSON tree
        Client-->>Nodes: MagnoliaNode (page root)

        Nodes->>Schema: buildPageSchema(pageNode)
        note over Schema: Walk page.nodes (mgnl:area children)<br/>For each area → transformArea()<br/>For each mgnl:component → transformComponent()<br/>  extract template (mgnl:template)<br/>  extract properties (skip jcr:*, mgnl:audit)<br/>  recurse mgnl:area children → areas{}<br/>  collect mgnl:contentNode children → contentNodes{}

        Schema-->>Nodes: PageSchema { sourcePath, exportedAt, areas }
        Nodes-->>CLI: PageSchema

        CLI->>FS: writeFile("schema.json", json)
        FS-->>CLI: done
        CLI->>User: stderr: "Wrote schema with N areas, N components"

    else HTTP 4xx / 5xx
        Magnolia-->>Client: error response
        Client-->>CLI: throws Error("Magnolia API error 404: ...")
        CLI->>User: stderr: error message + process.exit(1)
    end

    note over User,FS: Same flow for other commands:<br/>get / list / print → stdout<br/>components → response.json (flat mgnl:component list)

    User->>CLI: npm run dev -- migrate [schema.json] [migration.json]

    CLI->>FS: readFile("schema.json") + readFile("migration.json")
    FS-->>CLI: PageSchema + MigrationConfig

    CLI->>MigrateAPI: migratePage(schema, migrationConfig)
    note over MigrateAPI: Resolve parentPath:<br/>migrationConfig.targetParentPath ?? sourcePath parent

    MigrateAPI->>TargetClient: POST /nodes/v1/website/{parentPath}
    note over MigrateAPI,TargetClient: body: { name, type: "mgnl:page", properties + mgnl:template }
    TargetClient->>Target: POST .rest-v2/nodes/v1/website/{parentPath}

    alt HTTP 2xx
        Target-->>TargetClient: created
        loop for each area
            MigrateAPI->>TargetClient: POST /nodes/v1/website/{pagePath}
            note over MigrateAPI,TargetClient: body: { name, type: "mgnl:area" }
            TargetClient->>Target: POST area node
            loop for each component
                MigrateAPI->>TargetClient: POST /nodes/v1/website/{areaPath}
                note over MigrateAPI,TargetClient: body: { name, type: "mgnl:component", properties + mgnl:template }<br/>Unmapped templates are skipped with a warning
                TargetClient->>Target: POST component node
                opt has contentNodes
                    MigrateAPI->>TargetClient: POST mgnl:contentNode children recursively
                end
                opt has nested areas
                    MigrateAPI->>TargetClient: POST nested area + component nodes recursively
                end
            end
        end
        MigrateAPI-->>CLI: done
        CLI->>User: stderr: "Migration complete: /page/path"
    else HTTP 4xx / 5xx
        Target-->>TargetClient: error response
        TargetClient-->>CLI: throws Error("Target API error ...")
        CLI->>User: stderr: error message + process.exit(1)
    end
